{
  "name": "kvisl",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Composable modelling language for design diagrams — normalizer slice",
  "scripts": {
    "build": "node tools/build-diagrams.mjs",
    "docs:build": "node tools/build-diagrams.mjs",
    "layout:examples": "node experiments/layouter/render-all.mjs",
    "layout:examples:debug": "node experiments/layouter/render-all.mjs --debug-routing",
    "layout:css-example": "node experiments/layouter/render.mjs examples/modelplane-fleet-inference/neon-infrastructure.tsx --output experiments/layouter/output/modelplane-fleet-inference-neon.svg",
    "layout:render": "node experiments/layouter/render.mjs",
    "normalize": "node tools/normalize.mjs",
    "test": "node --test tests/*.test.mjs experiments/layouter/test/*.test.mjs",
    "test:layouter": "node --test experiments/layouter/test/*.test.mjs"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  }
}
